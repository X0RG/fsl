{
    "linux": {
        "xdg_standard": [
            "/usr/share/applications",
            "/usr/local/share/applications",
            "~/.local/share/applications"
        ],
        "sandboxed_packages": [
            "/var/lib/flatpak/exports/share/applications",
            "~/.local/share/flatpak/exports/share/applications",
            "/var/lib/snapd/desktop/applications"
        ],
        "portable_fallback": [
            "~/.local/bin",
            "~/Applications"
        ],
        "system_and_manual_binaries": [
            "/usr/bin",
            "/usr/local/bin",
            "/opt"
        ],
        "developer_package_managers": [
            "~/.cargo/bin",
            "~/.npm-global/bin",
            "~/go/bin"
        ]
    },
    "macos": {
        "standard_bundles": [
            "/Applications",
            "/System/Applications",
            "/System/Applications/Utilities",
            "~/Applications"
        ],
        "system_core_bundles": [
            "/System/Library/CoreServices"
        ],
        "package_managers": [
            "/opt/homebrew/Caskroom",
            "/usr/local/Caskroom",
            "/opt/homebrew/bin",
            "/usr/local/bin"
        ],
        "application_support_helpers": [
            "/Library/Application Support"
        ]
    },
    "windows": {
        "registry_hives": [
            {
                "hive": "HKEY_LOCAL_MACHINE",
                "path": "Software\\Microsoft\\Windows\\CurrentVersion\\Uninstall",
                "architecture": "x64_or_Native"
            },
            {
                "hive": "HKEY_LOCAL_MACHINE",
                "path": "Software\\Wow6432Node\\Microsoft\\Windows\\CurrentVersion\\Uninstall",
                "architecture": "x86_Wow64"
            },
            {
                "hive": "HKEY_CURRENT_USER",
                "path": "Software\\Microsoft\\Windows\\CurrentVersion\\Uninstall",
                "architecture": "User_Specific"
            },
            {
                "hive": "HKEY_LOCAL_MACHINE",
                "path": "Software\\Microsoft\\Windows\\CurrentVersion\\App Paths",
                "architecture": "Execution_Aliases_Global"
            },
            {
                "hive": "HKEY_CURRENT_USER",
                "path": "Software\\Microsoft\\Windows\\CurrentVersion\\App Paths",
                "architecture": "Execution_Aliases_User"
            }
        ],
        "start_menu_shortcuts": [
            "C:\\ProgramData\\Microsoft\\Windows\\Start Menu\\Programs",
            "%USERPROFILE%\\AppData\\Roaming\\Microsoft\\Windows\\Start Menu\\Programs"
        ],
        "package_managers": [
            "C:\\Users\\%USERNAME%\\scoop\\apps",
            "C:\\ProgramData\\chocolatey\\lib",
            "%LOCALAPPDATA%\\Microsoft\\WindowsApps"
        ],
        "uwp_store_apps": [
            "C:\\Program Files\\WindowsApps",
            "C:\\ProgramData\\Microsoft\\Windows\\AppRepository"
        ]
    }
}